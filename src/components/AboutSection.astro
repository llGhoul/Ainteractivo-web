---
import { equipo } from '../data/images';
---
<section id="nosotros" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative min-w-0">
        <div
          class="aspect-[4/3] sm:aspect-video bg-slate-100 rounded-2xl sm:rounded-3xl overflow-hidden shadow-2xl relative group w-full"
        >
          <img
            src={equipo.src}
            alt="Equipo de Aprendizaje Interactivo SAS en oficina"
            width="1200"
            height="675"
            class="w-full h-full min-w-0 min-h-0 object-cover object-center"
            loading="lazy"
            decoding="async"
            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 600px"
          />
          <div class="absolute inset-0 bg-blue-600/10 mix-blend-multiply"></div>
        </div>
        <div
          class="absolute -bottom-6 -right-6 bg-white p-6 rounded-2xl shadow-xl border border-slate-100 hidden md:block"
        >
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-emerald-100 rounded-full flex items-center justify-center">
              <i data-lucide="award" class="text-emerald-600 w-6 h-6" aria-hidden="true"></i>
            </div>
            <div>
              <p class="text-sm text-slate-500">Comprometidos con</p>
              <p class="font-bold text-slate-800">La Excelencia</p>
            </div>
          </div>
        </div>
      </div>
      <div>
        <p class="section-label text-sm font-bold uppercase tracking-widest mb-4" aria-hidden="true">
          Sobre nosotros
        </p>
        <h2 class="text-4xl font-bold text-slate-900 mb-6">
          Expertos en transformar el aprendizaje digital
        </h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-8">
          Aprendizaje Interactivo SAS es una empresa especializada en software educativo, LMS,
          simuladores, contenido SCORM y capacitación corporativa en Colombia.
          <br /><br />
          Transformamos la forma en que las organizaciones enseñan, aprenden y capacitan mediante
          soluciones tecnológicas innovadoras que rompen las barreras del conocimiento tradicional.
        </p>
        <div class="grid grid-cols-2 gap-6">
          <div class="space-y-2">
            <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center">
              <i data-lucide="check" class="text-blue-600 w-5 h-5" aria-hidden="true"></i>
            </div>
            <h3 class="font-bold">Innovación</h3>
            <p class="text-sm text-slate-500">Tecnología de última generación.</p>
          </div>
          <div class="space-y-2">
            <div class="w-8 h-8 rounded-lg bg-orange-50 flex items-center justify-center">
              <i data-lucide="check" class="text-orange-600 w-5 h-5" aria-hidden="true"></i>
            </div>
            <h3 class="font-bold">Resultados</h3>
            <p class="text-sm text-slate-500">Impacto real en capacitación.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

