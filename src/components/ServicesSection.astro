---
import ServiceCard from './ServiceCard.astro';
import { services } from '../data/services';
---
<section id="servicios" class="py-24 bg-slate-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="section-label text-sm font-bold uppercase tracking-widest mb-4" aria-hidden="true">
        Servicios Especializados
      </p>
      <h2 class="text-4xl font-bold text-slate-900 mb-4">
        Soluciones a la medida de tu organización
      </h2>
      <p class="text-slate-600">
        Software educativo, LMS, simuladores 3D, contenido SCORM y capacitación corporativa a la medida de tu organización.
      </p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {services.map((service) => (
        <ServiceCard service={service} />
      ))}
    </div>
  </div>
</section>

