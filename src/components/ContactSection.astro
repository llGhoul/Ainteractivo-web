---
import { contact } from '../data/contact';
---
<section id="contacto" class="py-24 bg-slate-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="bg-white rounded-[2.5rem] shadow-2xl overflow-hidden border border-slate-100">
      <div class="grid lg:grid-cols-2">
        <div class="p-8 lg:p-16">
          <h2 class="text-3xl font-bold mb-8">Hablemos de tu próximo proyecto</h2>
          <form
            id="contact-form"
            action="https://formspree.io/f/mkoqjqno"
            method="POST"
            class="space-y-6"
          >
            <div class="grid md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label for="contact-name" class="text-sm font-medium text-slate-700">Nombre</label>
                <input
                  id="contact-name"
                  type="text"
                  name="name"
                  required
                  autocomplete="name"
                  placeholder="Tu nombre"
                  class="contact-input w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all invalid:border-red-300 invalid:ring-red-200"
                  aria-required="true"
                />
                <span class="contact-error text-sm text-red-500 hidden" data-for="name"></span>
              </div>
              <div class="space-y-2">
                <label for="contact-company" class="text-sm font-medium text-slate-700">Empresa</label>
                <input
                  id="contact-company"
                  type="text"
                  name="company"
                  autocomplete="organization"
                  placeholder="Tu empresa (opcional)"
                  class="contact-input w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all"
                />
              </div>
            </div>
            <div class="space-y-2">
              <label for="contact-email" class="text-sm font-medium text-slate-700">Correo electrónico</label>
              <input
                id="contact-email"
                type="email"
                name="email"
                required
                autocomplete="email"
                placeholder="correo@ejemplo.com"
                class="contact-input w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all invalid:border-red-300 invalid:ring-red-200"
                aria-required="true"
              />
              <span class="contact-error text-sm text-red-500 hidden" data-for="email"></span>
            </div>
            <div class="space-y-2">
              <label for="contact-message" class="text-sm font-medium text-slate-700">Mensaje</label>
              <textarea
                id="contact-message"
                name="message"
                rows="4"
                required
                placeholder="Cuéntanos sobre tu proyecto..."
                class="contact-input w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all invalid:border-red-300 invalid:ring-red-200"
                aria-required="true"
              ></textarea>
              <span class="contact-error text-sm text-red-500 hidden" data-for="message"></span>
            </div>
            <button
              type="submit"
              id="contact-submit"
              class="w-full py-4 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 shadow-lg shadow-blue-200 transition-all flex items-center justify-center gap-2 disabled:opacity-60 disabled:cursor-not-allowed focus-visible-btn"
            >
              <span class="btn-text">Enviar mensaje</span>
              <i data-lucide="send" class="w-5 h-5" aria-hidden="true"></i>
            </button>
            <div id="form-feedback" class="hidden rounded-xl p-4 text-sm" role="status" aria-live="polite"></div>
          </form>
        </div>
        <div class="bg-slate-900 p-8 lg:p-16 text-white relative contact-dark-panel">
          <h3 class="text-2xl font-bold mb-10">Información de contacto</h3>
          <div class="space-y-8">
            <div class="flex gap-4">
              <div
                class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center shrink-0"
              >
                <i data-lucide="map-pin" class="text-blue-400" aria-hidden="true"></i>
              </div>
              <div>
                <p class="font-medium">Nuestra Oficina</p>
                <p class="contact-dark-panel-text" set:html={`${contact.address}<br />${contact.building}, ${contact.city}`}></p>
              </div>
            </div>
            <div class="flex gap-4">
              <div
                class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center shrink-0"
              >
                <i data-lucide="phone" class="text-blue-400" aria-hidden="true"></i>
              </div>
              <div>
                <p class="font-medium">Teléfono</p>
                <p class="contact-dark-panel-text">{contact.phone}</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div
                class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center shrink-0"
              >
                <i data-lucide="clock" class="text-blue-400" aria-hidden="true"></i>
              </div>
              <div>
                <p class="font-medium">Horario de Atención</p>
                <p class="contact-dark-panel-text">{contact.openingHours}</p>
              </div>
            </div>
          </div>
          <div class="mt-12 rounded-2xl overflow-hidden border border-white/10 h-48">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d6688.184207509266!2d-74.06634469505579!3d4.626515658146852!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e3f9b7619f5f211%3A0xe2a3679e0493e8af!2sAprendizaje%20Interactivo%20SAS!5e0!3m2!1ses!2sco!4v1773163802653!5m2!1ses!2sco" 
              width="600" 
              height="450" 
              style="border:0;" 
              allowfullscreen loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

