---
import { contact } from '../data/contact';

const formspreeId = import.meta.env.PUBLIC_FORMSPREE_FORM_ID ?? 'mkoqjqno';
const formAction = `https://formspree.io/f/${formspreeId}`;
---
<section id="contacto" class="py-12 sm:py-16 lg:py-24 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="bg-white rounded-2xl sm:rounded-3xl lg:rounded-[2.5rem] shadow-2xl overflow-hidden border border-slate-100">
      <div class="grid grid-cols-1 lg:grid-cols-2 min-w-0">
        <!-- Formulario -->
        <div class="p-5 sm:p-6 md:p-8 lg:p-16 order-1 min-w-0">
          <h2 class="text-2xl sm:text-3xl font-bold mb-6 sm:mb-8 text-slate-900">Hablemos de tu próximo proyecto</h2>
          <form
            id="contact-form"
            action={formAction}
            method="POST"
            class="space-y-5 sm:space-y-6"
          >
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 sm:gap-6">
              <div class="space-y-2 min-w-0">
                <label for="contact-name" class="text-sm font-medium text-slate-700">Nombre</label>
                <input
                  id="contact-name"
                  type="text"
                  name="name"
                  required
                  autocomplete="name"
                  placeholder="Tu nombre"
                  class="contact-input w-full min-w-0 px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all invalid:border-red-300 invalid:ring-red-200 text-base"
                  aria-required="true"
                />
                <span class="contact-error text-sm text-red-500 hidden" data-for="name"></span>
              </div>
              <div class="space-y-2 min-w-0">
                <label for="contact-company" class="text-sm font-medium text-slate-700">Empresa</label>
                <input
                  id="contact-company"
                  type="text"
                  name="company"
                  autocomplete="organization"
                  placeholder="Tu empresa (opcional)"
                  class="contact-input w-full min-w-0 px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all text-base"
                />
              </div>
            </div>
            <div class="space-y-2 min-w-0">
              <label for="contact-email" class="text-sm font-medium text-slate-700">Correo electrónico</label>
              <input
                id="contact-email"
                type="email"
                name="email"
                required
                autocomplete="email"
                placeholder="correo@ejemplo.com"
                class="contact-input w-full min-w-0 px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all invalid:border-red-300 invalid:ring-red-200 text-base"
                aria-required="true"
              />
              <span class="contact-error text-sm text-red-500 hidden" data-for="email"></span>
            </div>
            <div class="space-y-2 min-w-0">
              <label for="contact-message" class="text-sm font-medium text-slate-700">Mensaje</label>
              <textarea
                id="contact-message"
                name="message"
                rows="4"
                required
                placeholder="Cuéntanos sobre tu proyecto..."
                class="contact-input w-full min-w-0 px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all invalid:border-red-300 invalid:ring-red-200 text-base resize-y"
                aria-required="true"
              ></textarea>
              <span class="contact-error text-sm text-red-500 hidden" data-for="message"></span>
            </div>
            <button
              type="submit"
              id="contact-submit"
              class="w-full py-3.5 sm:py-4 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 shadow-lg shadow-blue-200 transition-all flex items-center justify-center gap-2 disabled:opacity-60 disabled:cursor-not-allowed focus-visible-btn text-base"
            >
              <span class="btn-text">Enviar mensaje</span>
              <i data-lucide="send" class="w-5 h-5" aria-hidden="true"></i>
            </button>
            <div id="form-feedback" class="hidden rounded-xl p-4 text-sm" role="status" aria-live="polite"></div>
          </form>
        </div>
        <!-- Información de contacto -->
        <div class="bg-slate-900 p-5 sm:p-6 md:p-8 lg:p-16 text-white relative contact-dark-panel order-2 min-w-0 flex flex-col">
          <h3 class="text-xl sm:text-2xl font-bold mb-6 sm:mb-8 lg:mb-10">Información de contacto</h3>
          <div class="space-y-6 sm:space-y-8 flex-1">
            <div class="flex gap-3 sm:gap-4 min-w-0">
              <div class="w-10 h-10 sm:w-12 sm:h-12 bg-white/10 rounded-xl flex items-center justify-center shrink-0">
                <i data-lucide="map-pin" class="text-blue-400 w-5 h-5 sm:w-6 sm:h-6" aria-hidden="true"></i>
              </div>
              <div class="min-w-0">
                <p class="font-medium text-sm sm:text-base">Nuestra Oficina</p>
                <p class="contact-dark-panel-text break-words" set:html={`${contact.address}<br />${contact.building}, ${contact.city}`}></p>
              </div>
            </div>
            <div class="flex gap-3 sm:gap-4 min-w-0">
              <div class="w-10 h-10 sm:w-12 sm:h-12 bg-white/10 rounded-xl flex items-center justify-center shrink-0">
                <i data-lucide="phone" class="text-blue-400 w-5 h-5 sm:w-6 sm:h-6" aria-hidden="true"></i>
              </div>
              <div class="min-w-0">
                <p class="font-medium text-sm sm:text-base">Teléfono</p>
                <p class="contact-dark-panel-text break-all sm:break-normal">{contact.phone}</p>
              </div>
            </div>
            <div class="flex gap-3 sm:gap-4 min-w-0">
              <div class="w-10 h-10 sm:w-12 sm:h-12 bg-white/10 rounded-xl flex items-center justify-center shrink-0">
                <i data-lucide="clock" class="text-blue-400 w-5 h-5 sm:w-6 sm:h-6" aria-hidden="true"></i>
              </div>
              <div class="min-w-0">
                <p class="font-medium text-sm sm:text-base">Horario de Atención</p>
                <p class="contact-dark-panel-text">{contact.openingHours}</p>
              </div>
            </div>
          </div>
          <div class="mt-8 sm:mt-10 lg:mt-12 rounded-xl sm:rounded-2xl overflow-hidden border border-white/10 h-40 sm:h-44 lg:h-48 w-full min-h-0">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d6688.184207509266!2d-74.06634469505579!3d4.626515658146852!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e3f9b7619f5f211%3A0xe2a3679e0493e8af!2sAprendizaje%20Interactivo%20SAS!5e0!3m2!1ses!2sco!4v1773163802653!5m2!1ses!2sco"
              class="w-full h-full min-h-[10rem]"
              style="border:0;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Ubicación de Aprendizaje Interactivo SAS"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

