<section id="contacto" class="py-24 bg-slate-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="bg-white rounded-[2.5rem] shadow-2xl overflow-hidden border border-slate-100">
      <div class="grid lg:grid-cols-2">
        <div class="p-8 lg:p-16">
          <h2 class="text-3xl font-bold mb-8">Hablemos de tu próximo proyecto</h2>
          <form id="contact-form" class="space-y-6">
            <div class="grid md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label class="text-sm font-medium text-slate-700">Nombre</label>
                <input
                  type="text"
                  class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all"
                />
              </div>
              <div class="space-y-2">
                <label class="text-sm font-medium text-slate-700">Empresa</label>
                <input
                  type="text"
                  class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all"
                />
              </div>
            </div>
            <div class="space-y-2">
              <label class="text-sm font-medium text-slate-700">Correo electrónico</label>
              <input
                type="email"
                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all"
              />
            </div>
            <div class="space-y-2">
              <label class="text-sm font-medium text-slate-700">Mensaje</label>
              <textarea
                rows="4"
                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all"
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full py-4 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 shadow-lg shadow-blue-200 transition-all flex items-center justify-center gap-2"
            >
              Enviar mensaje
              <i data-lucide="send" class="w-5 h-5"></i>
            </button>
          </form>
        </div>
        <div class="bg-slate-900 p-8 lg:p-16 text-white relative">
          <h3 class="text-2xl font-bold mb-10">Información de contacto</h3>
          <div class="space-y-8">
            <div class="flex gap-4">
              <div
                class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center shrink-0"
              >
                <i data-lucide="map-pin" class="text-blue-400"></i>
              </div>
              <div>
                <p class="font-medium">Nuestra Oficina</p>
                <p class="text-slate-400 text-sm">
                  Ak 7 #37 - 25 Oficina 1201<br />Edificio Lutaima, Bogotá, Colombia
                </p>
              </div>
            </div>
            <div class="flex gap-4">
              <div
                class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center shrink-0"
              >
                <i data-lucide="phone" class="text-blue-400"></i>
              </div>
              <div>
                <p class="font-medium">Teléfono</p>
                <p class="text-slate-400 text-sm">+57 310 2566170</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div
                class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center shrink-0"
              >
                <i data-lucide="clock" class="text-blue-400"></i>
              </div>
              <div>
                <p class="font-medium">Horario de Atención</p>
                <p class="text-slate-400 text-sm">Lunes a Viernes - Desde las 8:00 AM</p>
              </div>
            </div>
          </div>
          <div class="mt-12 rounded-2xl overflow-hidden border border-white/10 grayscale h-48">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3976.7198165335193!2d-74.0681326241432!3d4.626190042137087!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e3f9a2638a9d609%3A0xc3f8e438f292c300!2sAk.%207%20%2337-25%2C%20Bogot%C3%A1!5e0!3m2!1sen!2sco!4v1709800000000!5m2!1sen!2sco"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

