# Copia este archivo a .env y rellena los valores.
# Nunca subas .env al repositorio (ya está en .gitignore).

# Formspree: ID del formulario de contacto (visible en el frontend).
# Obtenerlo en https://formspree.io → tu formulario → Integration.
PUBLIC_FORMSPREE_FORM_ID=mkoqjqno

# Rutas privadas: contraseña para /admin y secreto para firmar la sesión.
# Genera un secreto aleatorio: openssl rand -hex 32
AUTH_SECRET=tu-secreto-aleatorio-muy-largo-aqui
AUTH_PASSWORD=tu-contraseña-admin
